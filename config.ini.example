# config.ini.example — copy to config.ini and fill in real values
# NEVER commit config.ini to git (it is in .gitignore)

[SUPABASE]
url              = https://YOUR_PROJECT.supabase.co
anon_key         = YOUR_SUPABASE_ANON_KEY
service_role_key = YOUR_SUPABASE_SERVICE_ROLE_KEY

[GOOGLE]
maps_api_key = YOUR_GOOGLE_MAPS_API_KEY

[ANTHROPIC]
api_key = YOUR_ANTHROPIC_API_KEY

[OPENAI]
api_key = YOUR_OPENAI_API_KEY
model   = gpt-4o

[SMTP]
host     = smtp.zoho.eu
port     = 465
user     = hello@vermarkter.eu
password = YOUR_SMTP_APP_PASSWORD
from     = Vermarkter <hello@vermarkter.eu>

[BREVO]
api_key     = YOUR_BREVO_API_KEY
from_email  = hello@vermarkter.eu
from_name   = Vermarkter
daily_limit = 300
